# =============================================================================
# Supabase (required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# =============================================================================

# Project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key (safe to expose; used with Row Level Security + Auth)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# Optional
# =============================================================================

# Override the default app URL (set this on Vercel to your production domain)
# Also required in Supabase → Authentication → URL Configuration:
#   Site URL: https://goats-traders-journal.vercel.app
#   Redirect URLs: https://goats-traders-journal.vercel.app/**
NEXT_PUBLIC_APP_URL=https://goats-traders-journal.vercel.app
